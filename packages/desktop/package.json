{
  "name": "easycode-desktop",
  "version": "1.1.38",
  "description": "Easy Code Desktop - AI-powered coding assistant with multi-model chat, code generation, tool integration, and Feishu collaboration",
  "type": "module",
  "main": "out/main/index.js",
  "author": "Easy Code Team",
  "license": "Apache-2.0",
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "build": "electron-vite build",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "pack:dir": "electron-vite build && node scripts/pack-installer.cjs --dir",
    "pack:win": "electron-vite build && node scripts/pack-installer.cjs --win",
    "pack:mac": "electron-vite build && node scripts/pack-installer.cjs --mac",
    "pack:linux": "electron-vite build && node scripts/pack-installer.cjs --linux",
    "pack:all": "electron-vite build && node scripts/pack-installer.cjs --win --mac --linux",
    "lint": "eslint . --ext .ts,.tsx"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.16.1",
    "@lydell/node-pty": "1.2.0-beta.12",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@nut-tree-fork/nut-js": "4.2.6",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "deepv-code-core": "file:../core",
    "fuzzysort": "^3.1.0",
    "highlight.js": "^11.11.1",
    "mermaid": "^11.15.0",
    "qrcode.react": "^4.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.9",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "42.5.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^4.0.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "typescript": "5.9.3",
    "vite": "^6.4.3",
    "zustand": "^5.0.2"
  },
  "engines": {
    "node": ">=20"
  }
}
