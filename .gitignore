# API keys and secrets
.env
.env~
.env.backup.*
.gemini_security
1
# deepv-code settings
.deepv/
!deepv/config.yaml

server/
# Note: .deepv-clipboard/ is NOT in gitignore so DeepV Code can access pasted images

# Dependency directory
node_modules
bower_components

vertex-server/
.vs/
# Editors
.idea
*.iml

# OS metadata
.DS_Store
Thumbs.db

# TypeScript build info files
*.tsbuildinfo
.tsbuildinfo

# Ignore built ts files
dist

# TypeScript编译产物（在源码目录中的）
# 注意：只忽略与.ts/.tsx文件同名的编译产物
packages/*/src/**/*.js
packages/*/src/**/*.d.ts
packages/*/src/**/*.js.map

# TypeScript编译产物（包根目录下的配置文件编译产物）
packages/*/vitest.setup.js
packages/*/vitest.setup.d.ts
packages/*/vitest.setup.js.map
packages/*/vitest.config.js
packages/*/vitest.config.d.ts
packages/*/vitest.config.js.map
packages/*/webview/vitest.config.js

# 构建缓存文件
.build-cache.json
**/.build-cache.json

# Docker folder to help skip auth refreshes
.docker

bundle

# Test report files
junit.xml
packages/*/coverage/

# Generated files
packages/cli/src/generated/
.integration-tests/
packages/vscode-ide-companion/*.vsix

.augment/
.cursor/
temp
packages/vscode-ui-plugin/webview/build
remote-client/build
.deepvcode
.npmrc

# Temporary backup during publish
.publish-backup

# Build artifacts
*.tgz

# Log files
*.log

packages/cli/clipboard/

# Debug exports (local diagnostics)
debug_export_*.md
probe-output.jsonl

# Local runtime config & artifacts (per-project, never commit)
.easycode/
.easycode-bak/
.easycode-user/

# Desktop (Electron) build artifacts
packages/desktop/out/
packages/desktop/release/
packages/desktop/node_modules/
packages/desktop/*.tsbuildinfo

# Desktop dev/run logs (local diagnostics)
desktop-dev.log
desktop-prod.log
desktop-prod.log.err
.codex/ 
